---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Not Found">
  <section class="container mx-auto px-4 py-24 text-center">
    <h1 class="text-6xl font-bold mb-4">404</h1>
    <p class="text-xl text-muted-foreground mb-8">Page not found</p>
    <a href="/" class="inline-flex items-center justify-center rounded-xl px-6 h-12 bg-primary text-primary-foreground hover:bg-primary/90 transition-colors">
      Go Home
    </a>
  </section>
</BaseLayout>
